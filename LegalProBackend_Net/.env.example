# ────────────────────────────────────────────────
# LegalPro - Backend .NET (Railway)
# Variables de entorno requeridas en Railway.
# Para desarrollo local: dotnet user-secrets set "Key" "Value"
#   (desde la carpeta LegalPro.Api)
# ────────────────────────────────────────────────

# PostgreSQL Railway Plugin
# Obtener de: Railway Dashboard → legalpro-postgres → Connect
ConnectionStrings__DefaultConnection=Host=roundhouse.proxy.rlwy.net;Port=PORT;Database=railway;Username=postgres;Password=PASSWORD;SSL Mode=Require;Trust Server Certificate=True;Pooling=True

# Para desarrollo local con docker-compose:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=legalpro;Username=postgres;Password=postgres;SSL Mode=Disable;Trust Server Certificate=True

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...

# JWT — mismo secreto que el backend Node
JWT_SECRET=genera-un-secreto-de-64-bytes-minimo

# Railway asigna esto automáticamente
PORT=8080
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
