# ────────────────────────────────────────────────
# LegalPro - Backend .NET (Railway)
# Variables de entorno requeridas en Railway o en
# User Secrets (desarrollo local)
# ────────────────────────────────────────────────
# Para desarrollo local: dotnet user-secrets set "Gemini:ApiKey" "AIzaSy..."
#   (desde la carpeta LegalPro.Api)

# PostgreSQL Supabase (https://supabase.com/dashboard → Settings → Database)
ConnectionStrings__DefaultConnection=Host=aws-0-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.TU_REF;Password=TU_PASSWORD;SSL Mode=Require;Trust Server Certificate=True

# Supabase Admin (https://supabase.com/dashboard → Settings → API)
SUPABASE_URL=https://TU_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...

# JWT (usar valor largo y aleatorio)
JWT_SECRET=genera-un-secreto-de-64-bytes-minimo

# Railway asigna esto automáticamente
PORT=8080
